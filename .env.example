# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_project_key_here

# Resend (newsletter)
# Get API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxx
# Create audience at https://resend.com/audiences, then copy its ID
RESEND_AUDIENCE_ID=your_audience_id_here

# Site URL — used in email templates for image paths (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://yonkolevel.com

# Secret for internal-only API routes (send-test, preview). Generate with: openssl rand -hex 32
INTERNAL_SECRET=your_secret_here
